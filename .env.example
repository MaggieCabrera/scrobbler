# App-level keys — registered once by the developer, not per user.
# Users authenticate via QR code on first run; no account details go here.

# Last.fm: free key at https://www.last.fm/api/account/create
LASTFM_API_KEY=
LASTFM_API_SECRET=

# Fingerprint backends — comma-separated, tried in order, first match wins.
# shazam:   built for mic recordings, handles room audio well, sends a WAV snippet
# acoustid: open source community database, sends only a fingerprint string (no audio)
#           works best with clean/close-mic signal (e.g. Pi with INMP441 next to speaker)
# Default: shazam,acoustid  — Shazam first (better for mic), AcoustID as fallback
# Pi production: FINGERPRINT_BACKENDS=acoustid,shazam  (AcoustID first, Shazam fallback)
# FINGERPRINT_BACKENDS=shazam,acoustid

# Optional: override system default audio input device (run: python -c "import sounddevice as sd; print(sd.query_devices())")
# AUDIO_DEVICE=
